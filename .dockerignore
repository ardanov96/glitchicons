# .dockerignore — Glitchicons v1.4.0
# Exclude files from Docker build context

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Go build artifacts (rebuilt inside Docker)
bin/*.exe
bin/*-linux-*
bin/*-darwin-*
bin/*-windows-*

# Dev + test
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
*.log

# Data directories (mounted as volumes)
findings/
engagements/

# Git
.git/
.gitignore
.github/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
